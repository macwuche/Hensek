modules = ["nodejs-20", "web"]
run = "cd /home/runner/workspace/client && npx vite build && cd /home/runner/workspace/server && npx tsx src/index.ts"

[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 npm run dev"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd server && NODE_ENV=production npx tsx src/index.ts"]
build = ["sh", "-c", "cd client && npx vite build"]
