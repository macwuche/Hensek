modules = ["nodejs-20", "web"]
run = "cd /home/runner/workspace/client && npx vite build && cd /home/runner/workspace/server && npx tsx src/index.ts"

[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3001
externalPort = 8000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 3003

[[ports]]
localPort = 5002
externalPort = 4200

[[ports]]
localPort = 5003
externalPort = 5173

[[ports]]
localPort = 5004
externalPort = 6000

[[ports]]
localPort = 5005
externalPort = 6800

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 3000

[[ports]]
localPort = 5175
externalPort = 3001

[[ports]]
localPort = 5176
externalPort = 3002

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
